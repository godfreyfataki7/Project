<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Karibu Mpendwa ❤️</title>
    <style>
    
        body {
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(45deg, #ff0055, #4b0082, #000000);
            background-size: 400% 400%;
            animation: bgAnim 10s infinite alternate;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            color: white;
            cursor: default;
        }

        @keyframes bgAnim {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }

        .card {
            background: rgba(0, 0, 0, 0.7);
            padding: 40px;
            border-radius: 25px;
            backdrop-filter: blur(15px);
            border: 2px solid rgba(255, 0, 85, 0.5);
            text-align: center;
            box-shadow: 0 0 30px rgba(255, 0, 85, 0.4);
            max-width: 400px;
            z-index: 100;
        }

        .btn {
            background: #25D366;
            color: white;
            padding: 15px 35px;
            font-size: 1.4em;
            text-decoration: none;
            border-radius: 50px;
            display: inline-block;
            margin-top: 20px;
            font-weight: bold;
            box-shadow: 0 0 20px #25D366;
            animation: heartbeat 1.5s infinite;
        }

        @keyframes heartbeat {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }

        /* Sparkles */
        .sparkle {
            position: absolute;
            background: white;
            border-radius: 50%;
            pointer-events: none;
            animation: fly 5s linear infinite;
        }

        @keyframes fly {
            0% { transform: translateY(0) scale(0); opacity: 1; }
            100% { transform: translateY(-100vh) scale(1.5); opacity: 0; }
        }
    </style>
</head>
<body oncontextmenu="return false;">

    <div class="card">
        <h1 style="color: #ff0055;">KWA AJILI YAKO ❤️</h1>
        <p>Tumekuwa tukikungoja kwa hamu sana. Uwepo wako hapa utaleta furaha, upendo na amani katika familia yetu. Usibaki nje, bonyeza kitufe hapa chini tuwe sote</p>
        <a href="https://chat.whatsapp.com/BCyAv2wMnrD5gIjQaSbCx0?mode=gi_t" class="btn">JIUNGE SASA</a>
    </div>

    <audio id="loveMusic" loop>
        <source src="https://raw.githubusercontent.com/godfreyfataki7/Love-/main/See%20you%20again.mp3" type="audio/mpeg">
    </audio>

    <script>
    // 1. USALAMA: Zuia Right Click & Shortcuts
    document.addEventListener('contextmenu', event => event.preventDefault());

    document.onkeydown = function(e) {
        if (e.keyCode == 123 || 
            (e.ctrlKey && e.shiftKey && (e.keyCode == 73 || e.keyCode == 74)) || 
            (e.ctrlKey && e.keyCode == 85)) {
            return false;
        }
    };

    // 2. KAZI YA SAUTI (SPEECH & MUSIC)
    function startExperience() {
        // A. Sauti ya kuongea (Speech Synthesis)
        const synth = window.speechSynthesis;
        const ujumbe = new SpeechSynthesisUtterance("You are warmly welcome, dear one. Your presence here is truly valued. Click the green button to join our family.");
        
        ujumbe.lang = 'en-US'; // Lugha ya Kiingereza
        ujumbe.rate = 0.9;      // Kasi ya kuongea
        
        // Safisha sauti zozote zinazoendelea kabla ya kuanza mpya
        synth.cancel();
        synth.speak(ujumbe);

        // B. Muziki wa Nyuma
        const music = document.getElementById('loveMusic');
        if (music) {
            music.volume = 0.2; 
            music.play().catch(error => console.log("Muziki umezuiwa: ", error));
        }
    }

    // Trigger: Mtu akigusa popote kwenye "document" mara ya kwanza
    document.addEventListener('click', startExperience, { once: true });

    // 3. ANIMATION YA SPARKLES
    function createSparkle() {
        const sparkle = document.createElement('div');
        sparkle.style.position = 'absolute';
        sparkle.style.background = 'white';
        sparkle.style.borderRadius = '50%';
        sparkle.style.pointerEvents = 'none';
        
        const size = Math.random() * 5 + 2 + 'px';
        sparkle.style.width = size;
        sparkle.style.height = size;
        sparkle.style.left = Math.random() * 100 + 'vw';
        sparkle.style.top = '100vh';
        
        const duration = Math.random() * 3 + 2;
        sparkle.style.transition = `transform ${duration}s linear, opacity ${duration}s`;
        
        document.body.appendChild(sparkle);

        // Animate manually for better control
        setTimeout(() => {
            sparkle.style.transform = `translateY(-110vh) scale(1.5)`;
            sparkle.style.opacity = '0';
        }, 50);

        setTimeout(() => sparkle.remove(), duration * 1000);
    }
    setInterval(createSparkle, 150);
    </script>
</body>
</html>
